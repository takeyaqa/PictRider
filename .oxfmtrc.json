{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "overrides": [
    {
      "files": ["*.js", "*.jsx", "*.ts", "*.tsx"],
      "options": {
        "semi": false,
        "singleQuote": true
      }
    }
  ],
  "sortTailwindcss": {
    "stylesheet": "./src/styles.css"
  }
}
